# ============================================================
# .gitignore for E-Voting Application
# ============================================================


# ----------------------------------------------------------
# SENSITIVE DATA & CREDENTIALS
# ----------------------------------------------------------

# Application data file (contains voter/candidate records)
evoting_data.json

# Environment variable files (API keys, secrets, DB passwords)
.env
.env.*
*.env
secrets.json
credentials.json

# Private keys & certificates
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Any config overrides with real secrets
local_config.py
local_settings.py


# ----------------------------------------------------------
# PYTHON
# ----------------------------------------------------------

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
*.coveragerc

# mypy / type checkers
.mypy_cache/
.dmypy.json

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# Unit test logs
test-results/
test_output/


# ----------------------------------------------------------
# DATABASE & LOGS
# ----------------------------------------------------------

# SQLite databases
*.db
*.sqlite3
*.sqlite

# Log files
*.log
logs/

# Backup files
*.bak
*.backup


# ----------------------------------------------------------
# OPERATING SYSTEM FILES
# ----------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~


# ----------------------------------------------------------
# EDITORS & IDEs
# ----------------------------------------------------------

# VS Code
.vscode/

# PyCharm / JetBrains
.idea/

# Vim / Emacs swap files
*.swp
*.swo
*~


# ----------------------------------------------------------
# MISCELLANEOUS
# ----------------------------------------------------------

# Temporary files
*.tmp
*.temp
tmp/
temp/
